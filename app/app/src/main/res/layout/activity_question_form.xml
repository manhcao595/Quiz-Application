<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nội dung câu hỏi"/>

        <EditText
            android:id="@+id/edtAnswerA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Đáp án A"/>

        <EditText
            android:id="@+id/edtAnswerB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Đáp án B"/>

        <EditText
            android:id="@+id/edtAnswerC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Đáp án C"/>

        <EditText
            android:id="@+id/edtAnswerD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Đáp án D"/>

        <Spinner
            android:id="@+id/spCorrectAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnSaveQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu"
            android:background="@drawable/bg_button_gradient"/>

    </LinearLayout>

</ScrollView>