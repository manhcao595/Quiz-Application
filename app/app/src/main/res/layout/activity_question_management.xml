<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ CÂU HỎI"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="10dp"
        android:textColor="#222222"/>

    <EditText
        android:id="@+id/edtNoiDung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nội dung câu hỏi"/>

    <EditText
        android:id="@+id/edtA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Đáp án A"/>

    <EditText
        android:id="@+id/edtB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Đáp án B"/>

    <EditText
        android:id="@+id/edtC"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Đáp án C"/>

    <EditText
        android:id="@+id/edtD"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Đáp án D"/>

    <EditText
        android:id="@+id/edtDapAnDung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Đáp án đúng (A/B/C/D)"
        android:layout_marginBottom="10dp"/>

    <!-- HÀNG NÚT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnThemCauHoi"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Thêm"
            android:background="@drawable/bg_button_gradient"/>

        <Button
            android:id="@+id/btnSuaCauHoi"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Sửa"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_gradient"/>

        <Button
            android:id="@+id/btnXoaCauHoi"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Xóa"
            android:background="@drawable/bg_button_gradient"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="← Quay lại"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_button_gradient"/>

    <ListView
        android:id="@+id/lvCauHoi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>